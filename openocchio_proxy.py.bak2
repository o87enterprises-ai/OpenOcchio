import json
import math
import re
import requests
from mitmproxy import http, ctx

# AI hosts we care about
AI_HOSTS = [
    "claude.ai",
    "api.anthropic.com",
    "chat.deepseek.com",
]

# Ollama judge endpoint
OLLAMA_URL = "http://localhost:11434/api/generate"

# Overlay update endpoint
OVERLAY_URL = "http://localhost:9876/update"


def response(flow: http.HTTPFlow) -> None:
    host = flow.request.pretty_host

    # Only process recognised AI hosts
    if not any(h in host for h in AI_HOSTS):
        return

    print(f">>> AI response from {host}{flow.request.path} <<<")
    ctx.log.info(f"AI response from {host}{flow.request.path}")

    content_type = flow.response.headers.get("content-type", "")
    resp_data = None

    # Try plain JSON first (non-streaming endpoints)
    if "application/json" in content_type:
        try:
            resp_data = json.loads(flow.response.text)
        except:
            ctx.log.info("Response JSON parsing failed, skipping")
            return
    elif "text/event-stream" in content_type:
        # Streaming SSE response – collect the final text
        full_text = ""
        for line in flow.response.text.split("\n"):
            if line.startswith("data: "):
                data_str = line[6:]
                if data_str.strip() == "[DONE]":
                    break
                try:
                    obj = json.loads(data_str)
                    # Claude content_block_delta
                    if obj.get("type") == "content_block_delta":
                        delta = obj.get("delta", {})
                        if delta.get("type") == "text_delta":
                            full_text += delta.get("text", "")
                    # DeepSeek / OpenAI style
                    elif "choices" in obj and len(obj["choices"]) > 0:
                        delta = obj["choices"][0].get("delta", {})
                        content = delta.get("content", "")
                        if content:
                            full_text += content
                except:
                    pass
        if full_text:
            resp_data = {"choices": [{"message": {"content": full_text}}]}
        else:
            ctx.log.info("SSE stream contained no text, skipping")
            return
    else:
        ctx.log.info(f"Unhandled content-type: {content_type}, skipping")
        return

    conf = None

    # 1. Try direct token logprobs (OpenAI style)
    try:
        content = resp_data["choices"][0].get("logprobs", {}).get("content", [])
        if content:
            probs = [math.exp(t.get("logprob", -100)) for t in content if t.get("logprob") is not None]
            if probs:
                conf = sum(probs) / len(probs)
    except:
        pass

    # 2. Fallback: ask local Ollama judge
    if conf is None:
        ai_text = ""
        try:
            ai_text = resp_data["choices"][0]["message"]["content"]
        except:
            try:
                ai_text = resp_data.get("response", "")
            except:
                pass

        if ai_text:
            prompt = (
                f'Rate how CONFIDENT this AI response sounds (0-100). '
                f'Consider hedging, refusal, or assertiveness. ONLY the number.\n'
                f'Response: "{ai_text}"\nConfidence:'
            )
            try:
                r = requests.post(OLLAMA_URL, json={
                    "model": "qwen2.5:3b",
                    "prompt": prompt,
                    "stream": False,
                    "options": {"temperature": 0.0, "num_predict": 5}
                }, timeout=15)
                judge_raw = r.json().get("response", "")
                m = re.search(r'\b(\d+(?:\.\d+)?)\b', judge_raw)
                if m:
                    num = float(m.group(1))
                    if num > 1: num /= 100.0
                    conf = max(0.0, min(1.0, num))
                ctx.log.info(f"Judge raw: '{judge_raw}' -> confidence {conf}")
            except Exception as e:
                ctx.log.error(f"Ollama call failed: {e}")
                conf = 0.5

    if conf is not None:
        try:
            requests.post(OVERLAY_URL, json={"confidence": conf}, timeout=1)
            ctx.log.info(f"Sent confidence {conf} to overlay")
        except Exception as e:
            ctx.log.error(f"Failed to update overlay: {e}")
